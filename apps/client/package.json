{
  "name": "@arxivflow/client",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "ArXivFlow frontend — semantic paper retrieval & embedding atlas",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.10",
    "prettier": "3.9.4",
    "sass": "1.101.0",
    "typescript": "6.0.3"
  },
  "engines": {
    "bun": ">=1.2.0",
    "node": ">=22.11.0"
  }
}
