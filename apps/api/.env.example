# ---------- Data sources ----------
ENRICHED_DATASET_FILE=raw_dataset_enriched_cleaned.jsonl
EMBEDDING_DATABASE_PATH=embeddings
ATLAS_PROJECTION_FILE=embeddings/atlas.json

# ChromaDB collection name (set by papervec to its WANDB_PROJECT_NAME).
EMBEDDING_COLLECTION_NAME=ArXivFlow

# ---------- Dense search (SPECTER2 ad-hoc query encoder) ----------
# Semantic Search v2 encodes the free-text query with the ad-hoc query adapter over the same base
# SPECTER2 model that produced the stored proximity document vectors, then ranks by cosine. Loaded
# lazily on the first dense search. Must match the base model papervec embedded the corpus with.
SPECTER2_BASE_MODEL=allenai/specter2_base
SPECTER2_QUERY_ADAPTER=allenai/specter2_adhoc_query
SPECTER2_MAX_SEQ_LENGTH=512

# ---------- HTTP server ----------
API_HOST=0.0.0.0
API_PORT=8000

# Comma-separated list of allowed CORS origins for the Next.js client.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ---------- Atlas projection (scripts/build_atlas.py) ----------
# Number of KMeans clusters used to colour the embedding atlas (papers carry no arXiv category).
ATLAS_CLUSTERS=8
# UMAP neighbourhood size / minimum distance for the 2D layout.
ATLAS_UMAP_NEIGHBORS=15
ATLAS_UMAP_MIN_DIST=0.1

# ---------- Miscellaneous ----------
RANDOM_SEED=42
