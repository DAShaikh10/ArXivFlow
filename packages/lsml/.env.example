# ---------- GliNER ----------
# Adjust between 0.3 - 0.5 for more/less sensitivity.
SENSITIVITY_THRESHOLD=0.5
GLINER_MODEL_NAME=urchade/gliner_large-v2.1

# ---------- Label Studio & ML Backend----------
# Variable names strictly follow:
# https://github.com/HumanSignal/label-studio-ml-backend/tree/master/label_studio_ml/examples/gliner#configuration
BASIC_AUTH_USER=# USERNAME_HERE
BASIC_AUTH_PASS=# PASSWORD_HERE
LABEL_STUDIO_URL=http://label-studio:8080
LABEL_STUDIO_API_KEY=# API_KEY_HERE

# ---------- Weights and Biases ----------
WANDB_API_KEY=# API_KEY_HERE
WANDB_PROJECT_NAME=ArXivFlow
