# ---------- GliNER ----------
# Adjust between 0.3 - 0.5 for more/less sensitivity.
SENSITIVITY_THRESHOLD=0.5
GLINER_MODEL_NAME=urchade/gliner_large-v2.1

# ---------- Dataset ----------
CLEANED_DATASET_FILE=raw_dataset_enriched_cleaned.jsonl
GLINER_NER_ANNOTATION_FILE=gliner_ner_annotation.jsonl

# ---------- Label Studio ----------
# /setup endpoint timeout in seconds. Used with label-studio-ml-backend i.e. lsml
ML_TIMEOUT_SETUP=60
# /predict endpoint timeout in seconds. Used with label-studio-ml-backend i.e. lsml
ML_TIMEOUT_PREDICTION=30

# ---------- vLLM NER ----------
HF_TOKEN=# HF_TOKEN_HERE
# WARN: This variable is overwritten in k8s.yml files.
LM_MODEL_NAME=microsoft/phi4
# Model input max. length. i.e. Prompt + Input. Rule of thumb: MAX_TOKENS + PROMPT + ABSTRACT <= MODEL_MAX_LEN.
MODEL_MAX_LEN=8192
MAX_TOKENS=4096
VLLM_TENSOR_PARALLEL_SIZE=2

# ---------- Weights and Biases ----------
WANDB_API_KEY=# API_KEY_HERE
WANDB_PROJECT_NAME=ArXivFlow
