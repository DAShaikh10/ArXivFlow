# ArXiv API
ARXIV_API_BASE_URL = "http://export.arxiv.org/api/query"
ARXIV_API_MAX_RESULTS_PER_REQUEST = 100 # Default should be 10 as per ArXiV API documentation but the upper limit is 30,000.
ARXIV_SEARCH_END_DATE = "202512310600" # Eg. 202512310600
ARXIV_SEARCH_START_DATE = "201501010600" # Eg. 201501010600
ARXIV_CATEGORY = "cs.CL" # Ref.: https://arxiv.org/category_taxonomy
ARXIV_SEARCH_MONTHS_BACK = 1
ARXIV_SEARCH_TOTAL_RESULTS = 500

# Semantic Scholar API
# Obtain from https://www.semanticscholar.org/product/api
# We can also work without the API key for simpler usecases. Please refer to the link above.
S2_API_KEY = # API_KEY_HERE
SEMANTIC_SCHOLAR_BATCH_SIZE = 100
SEMANTIC_SCHOLAR_CONCURRENCY = 1
SEMANTIC_SCHOLAR_DELAY_BETWEEN_BATCHES = 2 # seconds
SEMANTIC_SCHOLAR_API_BASE_URL = "https://api.semanticscholar.org/graph/v1/paper"
SEMANTIC_SCHOLAR_API_FIELDS = influentialCitationCount,url,references.externalIds,references.title,references.publicationDate,references.url

# Dataset
ENRICHED_DATASET_FILE = "raw_dataset_enriched.jsonl"
RAW_DATASET_FILE = "raw_dataset.jsonl"
