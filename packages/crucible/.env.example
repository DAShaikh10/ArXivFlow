# ---------- General API level configuration ----------
MAX_RETRIES=3

# ---------- ArXiv API ----------
ARXIV_API_BASE_URL=http://export.arxiv.org/api/query
# Default should be 10 as per ArXiV API documentation but the upper limit is 30,000.
ARXIV_API_MAX_RESULTS_PER_REQUEST=100
ARXIV_API_CONCURRENCY=1
# Seconds.
ARXIV_RETRY_DELAY=3
# Eg. 202512310600
ARXIV_SEARCH_END_DATE=202512310600
# Eg. 201501010600
ARXIV_SEARCH_START_DATE=201701010600
# Ref.: https://arxiv.org/category_taxonomy
ARXIV_CATEGORY=cs.CL
ARXIV_SEARCH_TOTAL_RESULTS=1000

# ---------- Semantic Scholar API ----------
# Obtain from https://www.semanticscholar.org/product/api
# We can also work without the API key for simpler usecases. Please refer to the link above.
S2_API_KEY=# API_KEY_HERE
SEMANTIC_SCHOLAR_BATCH_SIZE=500
SEMANTIC_SCHOLAR_CONCURRENCY=1
# Seconds.
SEMANTIC_SCHOLAR_DELAY_BETWEEN_BATCHES=1
SEMANTIC_SCHOLAR_API_BASE_URL=https://api.semanticscholar.org/graph/v1/paper
SEMANTIC_SCHOLAR_API_FIELDS=author,influentialCitationCount,url,references.externalIds,references.title,references.publicationDate,references.url
# Seconds.
SEMANTIC_SCHOLAR_RETRY_DELAY=3

# ---------- Weights and Biases ----------
WANDB_API_KEY=# API_KEY_HERE
WANDB_PROJECT_NAME=ArXivFlow

# ---------- Dataset ----------
ENRICHED_DATASET_FILE=raw_dataset_enriched.jsonl
RAW_DATASET_FILE=raw_dataset.jsonl

# ---------- Quality Checks ----------
PRE_ANNOTATION_MIN_ABSTRACT_WORDS=30
PRE_ANNOTATION_REPORT_PATH=raw_dataset_quality_report.json
