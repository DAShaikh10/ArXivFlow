# ---------- Dataset ----------
ADAPTER_NAME=allenai/specter2
BASE_MODEL_NAME=allenai/specter2_base
EMBEDDING_DATABASE_NAME=embeddings
ENRICHED_DATASET_FILE=raw_dataset_enriched_cleaned.jsonl

# ---------- Canonical tags ----------
# Label Studio annotation source for per-paper NER spans, normalized via the curated canonical map
# and written as boolean Chroma metadata keys ("{category}:{canonical}").
ANNOTATION_FILE=human-annotations.json
CANONICAL_MAP_FILE=canonical_map.json

# ---------- AllenAI / Specter ----------
# allenai/specter2_base model supports a max length of 512 tokens.
MAX_SEQ_LENGTH=512

# ---------- SciNCL (alternative dense encoder) ----------
SCINCL_MODEL_NAME=malteos/scincl
SCINCL_COLLECTION_NAME=ArXivFlow_scincl

# ---------- Weights and Biases ----------
WANDB_API_KEY=# API_KEY_HERE
WANDB_PROJECT_NAME=ArXivFlow
