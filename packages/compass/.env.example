# ---------- Inputs (produced by papervec + crucible + annotate into data/) ----------
EMBEDDING_DATABASE_NAME=embeddings
EMBEDDING_COLLECTION_NAME=ArXivFlow
ENRICHED_DATASET_FILE=raw_dataset_enriched_cleaned.jsonl

# Gold human annotations + canonical map → tag-overlap ground truth (read directly, not from Chroma).
ANNOTATION_FILE=human-annotations.json
CANONICAL_MAP_FILE=canonical_map.json

# ---------- Tier 0 evaluation ----------
# Comma-separated cut-offs for Recall@k / Precision@k / nDCG@k.
EVAL_K_VALUES=5,10,20
# A tag-overlap positive must share >= TAG_MIN_SHARED distinct canonical tags with the source
# (guards against single-generic-tag coincidences). TAG_JACCARD_MIN is an optional extra floor (0=off).
TAG_MIN_SHARED=2
TAG_JACCARD_MIN=0.0
# Output report (written under data/).
EVAL_REPORT_FILE=tier0_eval_report.json

# ---------- Track A: query-perturbation robustness (src.lib.recommend.perturb) ----------
# Sources sampled per signal, trials per source, and the RNG seed (all reproducible).
PERTURB_SAMPLE=150
PERTURB_TRIALS=5
PERTURB_SEED=20260701
# Real free-text perturbation (typo/word-drop → re-embed via SPECTER2 adhoc-query). Needs the
# `perturb-text` dependency group (`uv sync --group perturb-text`); off by default.
PERTURB_TEXT=0
PERTURB_TEXT_SAMPLE=60
PERTURB_REPORT_FILE=perturbation_report.json

# ---------- Track B: conclusion robustness (src.lib.recommend.robustness) ----------
# Bootstrap resamples, seed, and the minimum honest-column coverage below which a verdict is
# reported unfalsifiable rather than significant.
ROBUSTNESS_BOOT=2000
ROBUSTNESS_SEED=20260701
ROBUSTNESS_MIN_COVERAGE=30
# Include the reranker verdict (B3) — loads the cross-encoder. Off by default.
ROBUSTNESS_RERANKER=0
ROBUSTNESS_REPORT_FILE=robustness_report.json
